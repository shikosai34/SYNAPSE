# ==============================================================================
# FesFlow (SYNAPSE Monorepo) - Global Environment Variables Template
# ==============================================================================
#
# このファイルをコピーして、同ディレクトリに `.env` を作成してください。
# Copy this file to `.env` in the same directory and set the values.
#
# 2026-07-09: アプリ構成を現状に更新。
#   旧: apps/register(:3000) + apps/visitor(:3001) の2フロント
#   現: apps/app(:3000) 単一 SPA (2026-07-07 単一ドメイン化で統合)
#
# ==============================================================================

# ------------------------------------------------------------------------------
# API (apps/api - Cloudflare Workers / Wrangler)
# ------------------------------------------------------------------------------
# 注: Wrangler はローカル開発時に `apps/api/.dev.vars` を読み込みます。本リポジトリでは
# `apps/api/.dev.vars` はこのルート `.env` へのシンボリックリンク (ln -sf ../../.env
# apps/api/.dev.vars) になっており、API とフロントで同じファイルを共有します。
#
# Better Auth Configuration
BETTER_AUTH_SECRET="your-local-random-string-at-least-32-characters"
BETTER_AUTH_URL="http://localhost:8787"
# CORS_ORIGIN はカンマ区切りで複数オリジンを指定できます (better-auth の trustedOrigins が分割して読む)。
# フロントは単一 SPA (apps/app :3000)。localhost/127.0.0.1 は API 側で全ポート許可され、
# :3000 は trustedOrigins にハードコードもされているため、ここは主に本番/別ドメイン検証用途です。
CORS_ORIGIN="http://localhost:3000"
INITIAL_SUPER_ADMIN_EMAIL="admin@example.com"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# S3 / MinIO Configuration (Optional: Only if using local MinIO instead of Wrangler's R2 emulator)
# S3_ENDPOINT="http://localhost:9000"
# S3_BUCKET="fesflow-uploads"
# S3_REGION="us-east-1"
# S3_ACCESS_KEY_ID="minioadmin"
# S3_SECRET_ACCESS_KEY="minioadmin"
# S3_PUBLIC_URL="http://localhost:9000/fesflow-uploads"

# ------------------------------------------------------------------------------
# Frontend (apps/app :3000 - Vite SPA)
# ------------------------------------------------------------------------------
# Vite は接頭辞 `VITE_` が付いた変数のみクライアント側に露出させます。
# apps/app は vite.config.ts で `envDir: "../.."` を設定しているため、
# プロジェクトルートの `.env` を読み込みます。
# 本番ビルド時の値は .env.production に別途定義しています (localhost はここのローカル用)。
#
# 全フロントが参照する API のベースURL
VITE_API_URL="http://localhost:8787"

# 来場者(visitor)動線のベースURL。単一ドメイン化で app と同一オリジンなので :3000。
# (visitor-url.ts / IssueTab が別 SPA 前提の絶対URL遷移に使う名残)
VITE_VISITOR_URL="http://localhost:3000"

# サークルスタッフ(店頭スキャン等)動線のベースURL。同上、単一 SPA なので :3000。
VITE_STAFF_URL="http://localhost:3000"
