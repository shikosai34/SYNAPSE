# ==============================================================================
# FesFlow (SYNAPSE Monorepo) - Global Environment Variables Template
# ==============================================================================
#
# このファイルをコピーして、同ディレクトリに `.env` を作成してください。
# Copy this file to `.env` in the same directory and set the values.
#
# ==============================================================================

# ------------------------------------------------------------------------------
# API (apps/api - Cloudflare Workers / Wrangler)
# ------------------------------------------------------------------------------
# 注: Wrangler はローカル開発時に `apps/api/.dev.vars` を読み込みます。
# プロジェクトルートの `.env` へのシンボリックリンクを作成することで共有可能です。
# 例: `ln -sf ../../.env apps/api/.dev.vars`
#
# Better Auth Configuration
BETTER_AUTH_SECRET="your-local-random-string-at-least-32-characters"
BETTER_AUTH_URL="http://localhost:8787"
# CORS_ORIGIN はカンマ区切りで複数オリジンを指定できます (better-auth の trustedOrigins が分割して読む)。
# フロントは register(:3000) と visitor(:3001) の2つ。ローカルでは両ポートを許可します。
# (なお localhost:3000/3001 は trustedOrigins にハードコードもされているため、ここは主に本番用途)
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"
INITIAL_SUPER_ADMIN_EMAIL="admin@example.com"

# S3 / MinIO Configuration (Optional: Only if using local MinIO instead of Wrangler's R2 emulator)
# S3_ENDPOINT="http://localhost:9000"
# S3_BUCKET="fesflow-uploads"
# S3_ACCESS_KEY_ID="minioadmin"
# S3_SECRET_ACCESS_KEY="minioadmin"
# S3_PUBLIC_URL="http://localhost:9000/fesflow-uploads"

# ------------------------------------------------------------------------------
# Frontend (apps/register :3000 / apps/visitor :3001 - Vite SPA)
# ------------------------------------------------------------------------------
# Vite は接頭辞 `VITE_` が付いた変数のみクライアント側に露出させます。
# register/visitor とも vite.config.ts で `envDir: "../../"` を設定しているため、
# プロジェクトルートの `.env` を共有して読み込みます。
# 本番ビルド時の値は .env.production に別途定義しています (localhost はここのローカル用)。
#
# 全フロントが参照する API のベースURL
VITE_API_URL="http://localhost:8787"

# register → 来場者アプリ(visitor)へのリダイレクト先。兼: 来場者ポータルの「来場者」導線
VITE_VISITOR_URL="http://localhost:3001"

# サークルスタッフ用 register の URL (店頭スキャンQR / 権限スイッチでサークルへ移動)
# ローカルでは register は 1ポート(3000)なので staff/admin とも同じ値になる
VITE_STAFF_URL="http://localhost:3000"

# イベント/システム管理用 register の URL (権限スイッチで管理へ移動)
VITE_ADMIN_URL="http://localhost:3000"
