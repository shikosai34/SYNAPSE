# ==============================================================================
# FesFlow - 本番ビルド用フロントエンド環境変数 (2026-07-04 / 2026-07-07 単一ドメイン化)
# ==============================================================================
# `vite build` (mode=production) 時に自動で読み込まれ、フロントに焼き込まれる。
# ここに書けるのは VITE_ 接頭辞の「公開」値のみ。
# ⚠️ 機密 (BETTER_AUTH_SECRET 等) は絶対にここへ書かない。
#    このファイルは .gitignore 対象外＝コミットされる。機密は wrangler secret を使う。
#
# 本番ドメイン構成 (2026-07-07 単一ドメイン + パス分割):
#   来場者(visitor)        = https://fesflow.shikosai.net/
#   サークル(register)      = https://fesflow.shikosai.net/circle/*  (レジ=/circle/register)
#   イベント管理(register)   = https://fesflow.shikosai.net/event/*
#   システム管理(register)   = https://fesflow.shikosai.net/sys/*
#   API                    = https://fesflow.shikosai.net/api/*
# → すべて同一オリジン。各 VITE_*_URL は apex を指し、パスは各コード側で付与する。
# ------------------------------------------------------------------------------

# 全フロントが参照する API のベースURL (同一オリジン。fetchApi が /api/... を付ける)
VITE_API_URL="https://fesflow.shikosai.net"

# register → 来場者アプリへのリダイレクト先 (旧 /visitor/*, /menu, /my-order)
# 兼: 来場者ポータル(apex)の「来場者」導線
VITE_VISITOR_URL="https://fesflow.shikosai.net"

# サークルスタッフ入口 / 店頭スキャン (register)。コード側で /circle/login, /circle/checkin を付与
VITE_STAFF_URL="https://fesflow.shikosai.net"

# イベント/システム管理入口 (register)。コード側で /event/login, /sys/dashboard 等を付与
VITE_ADMIN_URL="https://fesflow.shikosai.net"
