{
  "name": "api",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --ip 0.0.0.0 --local-protocol https",
    "deploy": "CI=true WRANGLER_SEND_METRICS=false wrangler deploy",
    "check-types": "tsc -b",
    "cf-typegen": "wrangler types",
    "db:migrate:local": "CI=true wrangler d1 migrations apply fesflow-db --local",
    "db:migrate:remote": "CI=true wrangler d1 migrations apply fesflow-db --remote"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.5",
    "@fesflow/auth": "workspace:*",
    "@fesflow/db": "workspace:*",
    "@fesflow/storage": "workspace:*",
    "bcryptjs": "^2.4.3",
    "better-auth": "catalog:",
    "drizzle-orm": "^0.45.0",
    "hono": "catalog:",
    "nanoid": "^5.0.9",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@fesflow/config": "workspace:*",
    "@cloudflare/workers-types": "^4.20250620.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.13.11",
    "typescript": "^5.8.2",
    "wrangler": "^4.20.0"
  }
}
