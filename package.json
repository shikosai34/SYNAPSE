{
  "name": "fesflow",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "hono": "^4.8.2",
      "better-auth": "^1.4.5",
      "zod": "^4.1.13",
      "dotenv": "^17.2.2",
      "@libsql/client": "^0.14.0",
      "libsql": "^0.5.22"
    }
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:api": "turbo -F api dev",
    "dev:register": "turbo -F register dev",
    "dev:visitor": "turbo -F visitor dev",
    "deploy": "turbo deploy",
    "db:generate": "turbo -F @fesflow/db db:generate",
    "db:studio": "turbo -F @fesflow/db db:studio",
    "db:migrate:local": "turbo -F api db:migrate:local",
    "db:migrate:remote": "turbo -F api db:migrate:remote",
    "setup:env": "cp -n .env.example .env || true; ln -sf ../../.env apps/api/.dev.vars"
  },
  "dependencies": {
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "@types/node": "^22.13.11"
  },
  "packageManager": "bun@1.3.13"
}
